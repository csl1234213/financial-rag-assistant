# ============================================================
# Financial Research Copilot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ============================================================

# =========================
# API Keys
# =========================

DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# =========================
# App
# =========================

APP_ENV=development
APP_VERSION=4.3.0
LOG_LEVEL=INFO

# =========================
# API
# =========================

API_HOST=0.0.0.0
API_PORT=8000

# =========================
# Storage
# =========================

CHROMA_PATH=chroma_db
UPLOAD_DIR=storage/uploads
PDF_DIR=storage/pdfs

# =========================
# LLM
# =========================

LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1000

# =========================
# Redis
# =========================

REDIS_HOST=localhost
REDIS_PORT=6379

# =========================
# UI
# =========================

STREAMLIT_HOST=0.0.0.0
STREAMLIT_PORT=8501

PAGE_TITLE=Financial Research Copilot
PAGE_LAYOUT=wide

API_BASE_URL=http://financial-api:8000

UPLOAD_DIR=/app/uploads