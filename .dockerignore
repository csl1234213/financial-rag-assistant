# ============================================================
# .dockerignore
# ============================================================

# Version control
.git/
.gitignore
.gitattributes

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/
dist/
build/

# Virtual environments
.venv/
venv/
env/

# Testing
tests/
.pytest_cache/
.coverage
htmlcov/
coverage.xml
chroma_db_test*/

# Documentation
docs/
*.md
!README.md

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment
.env
.env.local
.env.production

# Docker
docker-compose*.yml
Dockerfile*
.dockerignore

# Trae
.trae/

# Streamlit (API doesn't need it)
ui/

# Working data (keep fresh)
chroma_db/
storage/uploads/
cache/