# ============================================================
# Dev Image — combined API + UI in one container
# ============================================================
FROM python:3.11.13-slim-bookworm

LABEL org.opencontainers.image.title="Financial Research Copilot - Dev"
LABEL org.opencontainers.image.version="4.3.0"
LABEL org.opencontainers.image.description="AI Financial Research Platform — Development Image"
LABEL org.opencontainers.image.licenses="MIT"
LABEL org.opencontainers.image.source="https://github.com/your-org/financial-rag-assistant"

WORKDIR /app

# Python best practices
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Python dependencies (dev: API + test tools)
COPY requirements/base.txt requirements/base.txt
COPY requirements/dev.txt requirements/dev.txt
RUN pip install --no-cache-dir -r requirements/dev.txt

# Application code
COPY . .

# Storage directories
RUN mkdir -p /app/storage/uploads /app/chroma_db

# Non-root user (security hardening)
RUN adduser --disabled-password --gecos "" appuser \
    && chown -R appuser:appuser /app
USER appuser

EXPOSE 8000 8501

# Run both API and UI via supervisord or a script
# For dev, use docker-compose.dev.yml which handles this with separate services
CMD ["uvicorn", "api.app:app", "--host", "0.0.0.0", "--port", "8000"]